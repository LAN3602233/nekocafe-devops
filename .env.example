# ───────────────────────────────────────────────────────────
# NekoCafé 环境变量模板
# 复制为 .env 并填入实际值。.env 已加入 .gitignore，不会提交到仓库。
# 符合 D3-1 §8 安全基线：Secret 严禁硬编码
# ───────────────────────────────────────────────────────────

# PostgreSQL
DATABASE_URL=postgresql://nekocafe:nekocafe@postgres:5432/reservation_db

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# 服务端口
PORT=8080
