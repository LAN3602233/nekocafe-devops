# .editorconfig — NekoCafé 编辑器统一配置
# 所有团队成员使用一致的缩进、换行、编码风格

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{md,rst}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.sh]
indent_style = tab

[Dockerfile]
indent_size = 2
